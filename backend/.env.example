# Server
PORT=3001
NODE_ENV=development

# Database
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/internship_db?schema=public"

# JWT
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars
JWT_EXPIRE=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Email (OPTIONAL) - used by the "forgot password" flow to send the 6-digit code.
# Leave these blank for local demos: the reset code is printed to the backend
# console instead of emailed. To enable real email, use a Gmail App Password.
EMAIL_USER=
EMAIL_PASS=
